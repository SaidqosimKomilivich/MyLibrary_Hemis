{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                ar.user_id, ar.read_at,\n                u.full_name as \"full_name!\", u.role as \"role!\"\n            FROM announcement_reads ar\n            JOIN users u ON ar.user_id = u.id\n            WHERE ar.announcement_id = $1\n            ORDER BY ar.read_at DESC\n            LIMIT $2 OFFSET $3\n            ",
