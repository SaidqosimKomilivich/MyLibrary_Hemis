  "query": "\n        SELECT id, full_name, role\n        FROM users\n        WHERE active = true\n          AND role IN ('admin', 'staff', 'teacher', 'student')\n          AND id != $3\n          AND (LOWER(full_name) LIKE LOWER($1))\n        ORDER BY full_name ASC\n        LIMIT $2 OFFSET $4\n        ",
