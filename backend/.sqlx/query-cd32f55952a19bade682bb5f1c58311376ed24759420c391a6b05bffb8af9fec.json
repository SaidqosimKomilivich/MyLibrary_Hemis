  "query": "\n        SELECT id, full_name, role\n        FROM users\n        WHERE active = true\n          AND role != 'admin'\n          AND (LOWER(full_name) LIKE LOWER($1))\n        ORDER BY full_name ASC\n        LIMIT $2\n        ",
