# ===================================================
# Backend uchun muhit o'zgaruvchilari shabloni
# Serverda bu faylni ko'chirib .env nomli fayl yarating:
#   cp .env.example .env
# Keyin qiymatlarni to'ldiring
# ===================================================

# PostgreSQL ulanish URL-i (docker compose da 'db' xosti ishlatiladi)
DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@db:5432/kutubxona_db

# JWT token uchun yashirin kalit (kamida 32 belgili, kuchli parol)
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_STRING_MIN_32_CHARS

# Token amal qilish muddatlari
ACCESS_TOKEN_EXPIRY_MINUTES=80
REFRESH_TOKEN_EXPIRY_DAYS=7

# Server sozlamalari (docker uchun 0.0.0.0 kerak)
SERVER_HOST=0.0.0.0
SERVER_PORT=8087

# CORS: Ruxsat etilgan manzillar (vergul bilan ajratilgan, bo'shliqsiz)
# Production domeningizni qo'shing — https:// bilan!
# Misol: CORS_ALLOWED_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz
CORS_ALLOWED_ORIGINS=https://yourdomain.uz

RUST_LOG=info

# Superadmin ma'lumotlari (birinchi ishga tushirishda yaratiladi)
ADMIN_LOGIN=superadmin
ADMIN_PAROL=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME="Kutubxona Admini"

# HEMIS API sozlamalari
HEMIS_BASE_URL=https://student.jbnuu.uz
HEMIS_TOKEN=YOUR_HEMIS_TOKEN
HEMIS_API_URL=https://student.jbnuu.uz/rest/v1/data
HEMIS_API_KEY=YOUR_HEMIS_API_KEY
